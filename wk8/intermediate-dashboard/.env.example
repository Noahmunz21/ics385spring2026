# ============================================================
# UH Maui Campus Dashboard - Environment Variables Template
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your actual keys
# NEVER commit the .env file to version control!
# .env is listed in .gitignore to prevent accidental commits.
# ============================================================

# --- OpenWeatherMap API ---
# Sign up at: https://openweathermap.org/api
# Free tier: 60 calls/min, 1,000,000 calls/month
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# --- RapidAPI (Chuck Norris Jokes) ---
# Sign up at: https://rapidapi.com
# Subscribe to: https://rapidapi.com/matchilling/api/chuck-norris-jokes-v1 (Free tier)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=matchilling-chuck-norris-jokes-v1.p.rapidapi.com

# --- JokeAPI ---
# No API key required!
# Docs: https://sv443.net/jokeapi/v2/
JOKE_API_BASE_URL=https://v2.jokeapi.dev

# --- Application Configuration ---
APP_NAME=UH Maui Campus Dashboard
DEFAULT_CITY=Kahului
CACHE_DURATION=600000
API_TIMEOUT=5000

# --- Development Settings ---
DEBUG_MODE=true
LOG_LEVEL=info
