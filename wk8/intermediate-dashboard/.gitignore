# ============================================================
# .gitignore - SECURITY CRITICAL
# Prevents sensitive files from being committed to Git
# ============================================================

# Environment variables - NEVER commit these!
.env
.env.local
.env.development
.env.production

# Node modules (if using a build tool)
node_modules/
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Build output
dist/
build/
